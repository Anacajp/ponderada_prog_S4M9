# ─── URLs base da API ASIS (staging) ─────────────────────────────────────────
UPLOAD_BASE_URL=https://upload.staging.asis.com.br
CORE_BASE_URL=https://core.staging.asis.com.br
RESULTADO_BASE_URL=https://resultado.staging.asis.com.br

# Aliases para compatibilidade
API_UPLOAD_URL=https://upload.staging.asis.com.br
API_CORE_URL=https://core.staging.asis.com.br
API_RESULTADO_URL=https://resultado.staging.asis.com.br

# ─── Autenticação ─────────────────────────────────────────────────────────────
APP_KEY=your-app-key-here
ACCOUNT_KEY=your-account-key-here

# ─── Configurações de polling e timeout ───────────────────────────────────────
# Tempo máximo aguardando processo finalizar (segundos)
PROCESS_MAX_WAIT_SECONDS=120
# Intervalo entre verificações de status (ms)
PROCESS_POLL_INTERVAL_MS=3000
# Timeout global dos testes Jest (ms)
TEST_TIMEOUT=60000
